{
  "info": {
    "name": "Healthcare Backend API",
    "_postman_id": "healthcare-api-collection",
    "description": "Complete API collection for Healthcare Backend - Auth, Patients, Doctors, Mappings",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "refresh_token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.tokens) {",
                  "  pm.collectionVariables.set('access_token', json.tokens.access);",
                  "  pm.collectionVariables.set('refresh_token', json.tokens.refresh);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"StrongPass123!\",\n  \"password_confirm\": \"StrongPass123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register/",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register", ""]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.tokens) {",
                  "  pm.collectionVariables.set('access_token', json.tokens.access);",
                  "  pm.collectionVariables.set('refresh_token', json.tokens.refresh);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"StrongPass123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login/",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login", ""]
            }
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.access) {",
                  "  pm.collectionVariables.set('access_token', json.access);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/token/refresh/",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "token", "refresh", ""]
            }
          }
        }
      ]
    },
    {
      "name": "Patients",
      "item": [
        {
          "name": "Create Patient",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Smith\",\n  \"date_of_birth\": \"1990-05-15\",\n  \"gender\": \"F\",\n  \"email\": \"jane@example.com\",\n  \"phone\": \"9876543210\",\n  \"address\": \"123 Main St, Mumbai\",\n  \"blood_group\": \"O+\",\n  \"medical_history\": \"No known allergies.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/patients/",
              "host": ["{{base_url}}"],
              "path": ["api", "patients", ""]
            }
          }
        },
        {
          "name": "List Patients",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/patients/",
              "host": ["{{base_url}}"],
              "path": ["api", "patients", ""]
            }
          }
        },
        {
          "name": "Get Patient Detail",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/patients/1/",
              "host": ["{{base_url}}"],
              "path": ["api", "patients", "1", ""]
            }
          }
        },
        {
          "name": "Update Patient",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"9123456789\",\n  \"address\": \"456 New Road, Delhi\",\n  \"medical_history\": \"Hypertension diagnosed 2023.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/patients/1/",
              "host": ["{{base_url}}"],
              "path": ["api", "patients", "1", ""]
            }
          }
        },
        {
          "name": "Delete Patient",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/patients/1/",
              "host": ["{{base_url}}"],
              "path": ["api", "patients", "1", ""]
            }
          }
        }
      ]
    },
    {
      "name": "Doctors",
      "item": [
        {
          "name": "Create Doctor",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alice Brown\",\n  \"specialization\": \"cardiology\",\n  \"license_number\": \"MH-DOC-2023-001\",\n  \"years_of_experience\": 12,\n  \"qualification\": \"MBBS, MD (Cardiology)\",\n  \"email\": \"alice.brown@hospital.com\",\n  \"phone\": \"9000012345\",\n  \"hospital_affiliation\": \"City Heart Hospital\",\n  \"available\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/doctors/",
              "host": ["{{base_url}}"],
              "path": ["api", "doctors", ""]
            }
          }
        },
        {
          "name": "List Doctors",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/doctors/",
              "host": ["{{base_url}}"],
              "path": ["api", "doctors", ""]
            }
          }
        },
        {
          "name": "List Doctors (Filter by Specialization)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/doctors/?specialization=cardiology",
              "host": ["{{base_url}}"],
              "path": ["api", "doctors", ""],
              "query": [
                { "key": "specialization", "value": "cardiology" }
              ]
            }
          }
        },
        {
          "name": "List Doctors (Filter by Availability)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/doctors/?available=true",
              "host": ["{{base_url}}"],
              "path": ["api", "doctors", ""],
              "query": [
                { "key": "available", "value": "true" }
              ]
            }
          }
        },
        {
          "name": "Get Doctor Detail",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/doctors/1/",
              "host": ["{{base_url}}"],
              "path": ["api", "doctors", "1", ""]
            }
          }
        },
        {
          "name": "Update Doctor",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"available\": false,\n  \"hospital_affiliation\": \"Metro General Hospital\",\n  \"years_of_experience\": 13\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/doctors/1/",
              "host": ["{{base_url}}"],
              "path": ["api", "doctors", "1", ""]
            }
          }
        },
        {
          "name": "Delete Doctor",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/doctors/1/",
              "host": ["{{base_url}}"],
              "path": ["api", "doctors", "1", ""]
            }
          }
        }
      ]
    },
    {
      "name": "Mappings",
      "item": [
        {
          "name": "Assign Doctor to Patient",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patient\": 1,\n  \"doctor\": 1,\n  \"notes\": \"Referred for cardiac evaluation.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/mappings/",
              "host": ["{{base_url}}"],
              "path": ["api", "mappings", ""]
            }
          }
        },
        {
          "name": "List All Mappings",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/mappings/",
              "host": ["{{base_url}}"],
              "path": ["api", "mappings", ""]
            }
          }
        },
        {
          "name": "Get Doctors by Patient",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/mappings/1/",
              "host": ["{{base_url}}"],
              "path": ["api", "mappings", "1", ""]
            }
          }
        },
        {
          "name": "Delete Mapping",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/mappings/delete/1/",
              "host": ["{{base_url}}"],
              "path": ["api", "mappings", "delete", "1", ""]
            }
          }
        }
      ]
    }
  ]
}